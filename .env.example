# Database
DATABASE_URL=postgresql://aim:changeme@localhost:5432/aim?schema=public
POSTGRES_PASSWORD=changeme

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# First sign-in with this email is auto-promoted to SUPER_ADMIN.
ADMIN_BOOTSTRAP_EMAIL=

# === Auth providers ===
# Enable the ones you want. Each provider also needs its credentials below.

AUTH_DISCORD=false
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

AUTH_GITHUB=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

AUTH_GOOGLE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Steam — no client id needed (uses OpenID 2.0). STEAM_API_KEY is optional;
# without it, persona names default to "Player <last6digits>".
AUTH_STEAM=false
STEAM_API_KEY=

# Local email + password. Registration UI not shipped yet — create users
# via Prisma Studio for now if you enable this provider.
AUTH_LOCAL=false
